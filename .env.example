# ── Impressum / Legal ──────────────────────────────────────────────
IMPRESSUM_FULL_NAME=
IMPRESSUM_EMAIL=
IMPRESSUM_PHONE=
IMPRESSUM_STREET=
IMPRESSUM_HOUSE_NR=
IMPRESSUM_ZIP=
IMPRESSUM_CITY=
IMPRESSUM_COUNTRY=

# ── GitHub API ────────────────────────────────────────────────────
# Personal access token (read-only, public repos)
GITHUB_TOKEN=
GITHUB_USERNAME=

# ── Contact Form (v2) ────────────────────────────────────────────
# Resend (https://resend.com) — email delivery for contact form
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
# For local development, use Cloudflare's always-passing test keys:
#   NEXT_PUBLIC_CAPTCHA_SITE_KEY=1x00000000000000000000AA
#   CAPTCHA_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# ── Site URL ──────────────────────────────────────────────────────
# Used for SEO metadata, sitemap, and OpenGraph URLs.
# Defaults to https://einfachvalle.de if not set.
# Set to Vercel preview URL during staging.
NEXT_PUBLIC_SITE_URL=
