{
  "singleQuote": false,
  "semi": true,
  "useTabs": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 80,
  "endOfLine": "lf",
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrderParserPlugins": ["typescript", "jsx"],
  "importOrder": [
    "^react$",
    "^react-dom",
    "^react-redux$",
    "^react-router",
    "^react-",
    "^@mui/",
    "^@reduxjs/toolkit",
    "^redux",
    "^@portfolio/shared",
    "<THIRD_PARTY_MODULES>",
    "^@/",
    "^\\.",
    "^.+\\.css$"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
